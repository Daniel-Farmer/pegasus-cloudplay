{
  "name": "pegasus-cloudplay",
  "version": "1.0.0",
  "description": "Play powerful PC games on any device instantly by streaming from the cloud",
  "main": "./out/main/index.js",
  "scripts": {
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "build:web": "vite build --config vite.config.web.ts"
  },
  "build": {
    "appId": "com.pegasus.cloudplay",
    "productName": "Pegasus CloudPlay",
    "directories": {
      "buildResources": "resources"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "dependencies": {
    "@fontsource/inter": "^5.0.0",
    "@supabase/supabase-js": "^2.97.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.378.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
